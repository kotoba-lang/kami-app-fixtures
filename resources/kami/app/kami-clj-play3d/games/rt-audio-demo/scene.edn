;; KAMI RT + binaural-audio demo — scene + executor recipes (ADR-0036/0045).
;; The host hardcodes no look; the game logic lives in logic.clj.

{:game/id    :gftd.games/rt-audio-demo
 :game/title "KAMI RT + Binaural Demo"

 :world {:player-speed 300.0
         :camera-dist  10.0
         :camera-height 4.0
         :ground-scale 0.02}

 :render/profiles
 {:player {:color [0.30 0.62 1.0] :w 0.9 :h 1.9 :glow 0.0}}

 :render/sky {:zenith  [0.20 0.42 0.78]
              :horizon [0.74 0.84 0.95]
              :sun-dir [-0.4 -0.85 -0.35]
              :sun     [1.0 0.96 0.85]}

 ;; kami.rt recipe selected by (rt-enable! "gi") — the host normalizes this via
 ;; kami.rt/pipeline and emits per-platform (WGSL ray-query / Metal RT / …).
 :rt/recipes
 {"gi" {:rt/name       "gi"
        :rt/accel      {:kind :bvh :builder :sah :refit :per-frame}
        :rt/integrator {:kind :path :max-bounces 4 :spp 8 :clamp 10.0}
        :rt/sampler    {:kind :sobol :seed 0}
        :rt/output     {:width 1280 :height 720 :format :rgba16f :denoise :svgf}}}

 ;; kami.binaural scene — the listener pose is driven live by (set-listener!).
 :binaural/hrtf    {:model :spherical-head :head-radius 0.0875 :max-ild-db 12.0}
 :binaural/rolloff {:kind :inverse :ref 1.0 :max 80.0 :factor 1.0}

 ;; cue bank (Web Audio synth on web; native mixer otherwise) — no asset files.
 :audio/cues
 {:step {:wave "triangle" :freq 180 :to 60 :dur 0.12 :gain 0.18}}}
